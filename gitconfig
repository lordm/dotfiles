[user]
  name = Marwan Osman
  email = marwan.aosman@gmail.com
  signingkey = /home/marwan/.ssh/id_ed25519_sk
[color]
  diff = auto
  status = auto
  branch = auto
  interactive = auto
  ui = true
  pager = true
[color "branch"]
  current = yellow reverse
  local = yellow
  remote = green
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
[color "status"]
  added = yellow
  changed = green
  untracked = cyan
[core]
  pager = less -FRSX
  whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
  editor=nvim
	excludesfile = /home/marwan/.gitignore
[alias]
  co = checkout
  ci = commit -m
  ciam = commit --amend
  fo = fetch origin
  pom = push origin master
  st = status
  df = diff
  br = branch
  lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  lgm = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=local --no-merges origin/master
  cleanup = ! git br --merged | grep -vE 'main' | xargs -n 1 git br -D
  nuke = !sh -c 'git branch -D $1 && git push origin :$1' -
[diff]
	tool = nvimdiff
[merge]
	tool = nvimdiff
[push]
	default = simple
[pull]
  rebase = false
[gpg]
  format = ssh
